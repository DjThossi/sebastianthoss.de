<div class="heading heading-v1 margin-top-20">
  <h1>Reisebilder aus Südostasien</h1>
  <p>Hier findet Ihr ein paar schöne Bilder und die <a href="{{ site.url }}/de/reiseblog/2025-vietnam-bali/">Blogposts</a> unserer Reise nach Singapur, Vietnam und Bali</p>
</div>

<!-- Six Columns -->
<div class="container content">

    <div class="row margin-bottom-30">
        {% set images =  source('imageData/2025-vietnam-bali.csv')|split(", ")|reverse %}

        {% for image in images %}
            <div class="col-sm-2 sm-margin-bottom-30">
                <a href="{{ site.url }}/assets/img/blog/2025-vietnam-bali/{{ image }}" rel="gallery3" class="fancybox img-hover-v1" title="{{ image }}">
                    <span><img class="img-responsive" src="{{ site.url }}/assets/img/blog/2025-vietnam-bali/small/{{ image }}" alt="{{ image }}"></span>
                </a>
            </div>
            {% if loop.index % 6 == 0 %}
                </div>
                <div class="row margin-bottom-30">
            {% endif %}
        {% endfor %}
    </div>

</div>
<!-- End Six Columns -->